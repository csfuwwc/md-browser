{
  "name": "md-browser",
  "version": "1.0.0",
  "description": "Local browser profile and proxy route manager for team workflows.",
  "author": "MD-Browser contributors",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csfuwwc/md-browser.git"
  },
  "bugs": {
    "url": "https://github.com/csfuwwc/md-browser/issues"
  },
  "homepage": "https://github.com/csfuwwc/md-browser#readme",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "mcp": "node mcp/md-browser-mcp.js",
    "desktop": "npm run tauri:dev",
    "tauri:web": "node scripts/build_tauri_web.cjs",
    "tauri:prepare": "node scripts/prepare_tauri_bundle.cjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:signer:generate": "tauri signer generate -w ~/.tauri/md-browser.key",
    "test": "node --test tests/*.test.js",
    "clean:dist": "node scripts/clean_dist.cjs dist dist-tauri src-tauri/target/release/bundle",
    "package:mac": "npm run tauri:build",
    "release:manifest": "node scripts/release_manifest.cjs",
    "release:manifest:tauri": "MD_BROWSER_RELEASE_MANIFEST_FORMAT=tauri node scripts/release_manifest.cjs",
    "release:prepare": "node scripts/prepare_release.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "lucide-static": "^1.17.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
