{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MD-Browser",
  "version": "1.1.2",
  "identifier": "com.local.md-browser",
  "build": {
    "frontendDist": "../dist-tauri/web",
    "devUrl": "http://127.0.0.1:18777",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run tauri:web && npm run tauri:prepare"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg"
    ],
    "resources": [
      "../tauri-bundle/runtime/node",
      "../tauri-bundle/app"
    ],
    "icon": [
      "../build/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/csfuwwc/md-browser/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCRUI2QkJBRDlCMEFDMDIKUldRQ3JMRFp1bXZyeTNPYUJwVDBvTVc1RGdVVXFZR1RKcUM5SEMvaTU0ajl6ZEdrZ0crUmRId20K"
    }
  }
}
